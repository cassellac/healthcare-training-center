  "weight_notes": {
    "regular": "Default weight for all UI icons (24–32px typical size)",
    "fill": "Solid fill — use for large banner icons (48px+) or high-contrast backgrounds",
    "duotone": "Two-tone effect — use for decorative large icons, room display icons",
    "bold": "Thicker strokes — use for emphasis or icon buttons (available but not primary)"
  },
  "sizing_guide": {
    "micro": {
      "size": "16px",
      "usage": "Inline badges, form labels, captions",
      "weight": "regular"
    },
    "small": {
      "size": "20px",
      "usage": "Icon buttons, nav icons, list items",
      "weight": "regular"
    },
    "default": {
      "size": "24px",
      "usage": "Most UI elements, course cards, buttons",
      "weight": "regular"
    },
    "large": {
      "size": "32px",
      "usage": "Room header cards, progress indicators",
      "weight": "regular"
    },
    "xlarge": {
      "size": "48px–64px",
      "usage": "Room display icons, hero sections",
      "weight": "fill or duotone"
    }
  },
  "usage_rules": {
    "color": "Always inherit parent text color or use defined color palette (#1E3A6E navy, #2B8FA9 teal, room colors). Never use arbitrary colors.",
    "spacing": "24px min padding around icons in clickable areas (touch target 44x44px minimum)",
    "alt_text": "Always provide meaningful alt text for screen readers (e.g., 'Complete Room 1' not just 'checkmark')",
    "animation": "Icons can transition color on hover (100ms ease-out). Never rotate or scale excessively.",
    "source": "Import from Phosphor Icons CDN or self-hosted fonts. Font name: PhosphorRegular, PhosphorFill, etc.",
    "no_decoration": "Never use emoji or custom graphics instead of Phosphor icons. Consistency is critical."
  },
  "import_instructions": {
    "web": "Link to Phosphor stylesheet: <link rel='stylesheet' href='https://unpkg.com/@phosphor-icons/web'> or self-hosted from assets/phosphor/",
    "usage_html": "<i class='ph ph-users'></i> for regular, <i class='ph-fill ph-shield-check'></i> for fill, <i class='ph-duotone ph-folder-open'></i> for duotone",
    "figma": "Install Phosphor Icons plugin in Figma, search by name (e.g., 'ph-users')",
    "svg": "Download SVGs from phosphoricons.com/get-started#svg-files, save to assets/icons/"
  }
}
