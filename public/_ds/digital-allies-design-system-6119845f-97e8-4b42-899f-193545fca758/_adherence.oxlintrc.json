{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "export/src/**",
              "social/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lexend Deca|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Lexend Deca, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-soft",
      "--bg",
      "--bg-alt",
      "--bone-white",
      "--border",
      "--border-1",
      "--border-dashed",
      "--border-hairline",
      "--border-soft",
      "--charcoal",
      "--content-max",
      "--dur-base",
      "--dur-pulse",
      "--dur-quick",
      "--dur-slow",
      "--ease-out",
      "--ease-snap",
      "--fg",
      "--fg-muted",
      "--fg-on-dark",
      "--fg-soft",
      "--field-border",
      "--font-body",
      "--font-details",
      "--font-headers",
      "--fs-body",
      "--fs-display",
      "--fs-h1",
      "--fs-h2",
      "--fs-h3",
      "--fs-h4",
      "--fs-micro",
      "--fs-nano",
      "--fs-small",
      "--grid-line",
      "--grid-line-strong",
      "--hairline",
      "--lace-step",
      "--lh-normal",
      "--lh-relaxed",
      "--lh-snug",
      "--lh-tight",
